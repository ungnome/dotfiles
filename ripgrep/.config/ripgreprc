# Search hidden files and directories.
--hidden

# Follow symbolic links.
--follow

# Don't respect ignore files (.gitignore, .ignore, etc.).
--no-ignore

# Exclude directories.
--glob=!{.git,.terraform,.svn,node_modulesTrash}

# Exclude file types.
--glob=!*.{lock}

# Exclude files.
--glob=!{package-lock.json}

# Searches case insensitively.
--smart-case
